@model IEnumerable<_14480_employes_managment.Models.Employee>

@{
    ViewData["Title"] = "Index";
}

<p>
    <a asp-action="Create" class="btn btn-primary"><i class="fa fa-plus"></i>Add New Intrument</a>
</p>
<div class="card">
    <div class="card-header">
        <h3 class="card-title">Instruments List</h3>
    </div>
    <div class="card-body">
        <table id="example1" class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.TipoInstrumento)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Instrumento)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.UsaCordas)
            </th>
            <th>
                Edit
            </th>
            <th>
                View
            </th>
            <th>
                Delete
            </th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.TipoInstrumento)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Instrumento)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.UsaCordas)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary"><i class="fa fa-pen"></i>Edit</a>
            </td>
            <td>
                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-warning"><i class="fa fa-eye"></i>View</a>
            </td>
            <td>
                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger"><i class="fa fa-trash"></i>Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>
</div>
</div>